# ==============================================================================
# SECURITY — NEVER COMMIT THESE
# ==============================================================================
.env
.env.*
!.env.sample

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.Python
pip-selfcheck.json

# Virtual environments
venv/
.venv/
env/
ENV/
.conda/

# ==============================================================================
# Data — Raw PDFs (large, copyrighted)
# ==============================================================================
data/raw/*.pdf
data/raw/*.PDF

# ==============================================================================
# Data — Generated / Processed (reproducible via setup.py)
# ==============================================================================
data/processed/parsed_pages.json
data/processed/chapters.json
data/processed/structured_chapters.json
data/processed/chunks.json
data/processed/enriched_chunks.json

# ==============================================================================
# Data — Audio (large binary, generated at runtime)
# ==============================================================================
data/audio_outputs/
data/raw_audio/*.wav
data/raw_audio/*.mp3

# ==============================================================================
# Data — Large ML Models (too big for GitHub, use Git-LFS or skip)
# ==============================================================================
data/models/
*.onnx
*.bin
*.pt
*.pth
*.safetensors

# ==============================================================================
# Databases — committed to repo so users skip the build pipeline
# NOTE: db/tesla.db and db/qdrant/ ARE committed intentionally.
# Only transient lock files are excluded.
# ==============================================================================
db/qdrant/.lock

# ==============================================================================
# IDE & OS Artifacts
# ==============================================================================
.vscode/
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ==============================================================================
# Logs & Temp
# ==============================================================================
*.log
*.tmp
*.bak
