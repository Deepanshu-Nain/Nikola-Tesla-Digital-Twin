# ==============================================================================
# SECURITY — NEVER COMMIT THESE
# ==============================================================================
.env
.env.*
!.env.sample

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.Python
pip-selfcheck.json

# Virtual environments
venv/
.venv/
env/
ENV/
.conda/

# ==============================================================================
# Data — Raw PDFs — NOW COMMITTED (all small enough for GitHub)
# ==============================================================================
# data/raw/*.pdf   <-- intentionally NOT ignored, PDFs ship with repo

# ==============================================================================
# Data — Processed JSONs — NOW COMMITTED (ships with repo)
# ==============================================================================
# data/processed/  <-- intentionally NOT ignored

# ==============================================================================
# Data — Reference Audio — NOW COMMITTED
# ==============================================================================
# data/raw_audio/tesla_reference.wav  <-- intentionally NOT ignored

# ==============================================================================
# Data — Runtime Audio Outputs (generated per session, do NOT commit)
# ==============================================================================
data/audio_outputs/*.wav
data/audio_outputs/*.mp3

# ==============================================================================
# Data — Large ML Models (too big for GitHub even with Git-LFS)
# ==============================================================================
data/models/*.onnx
data/models/*.bin
data/models/*.pt
data/models/*.pth
data/models/*.safetensors

# ==============================================================================
# Databases — committed to repo so users skip the build pipeline
# NOTE: db/tesla.db and db/qdrant/ ARE committed intentionally.
# Only the transient lock file is excluded.
# ==============================================================================
db/qdrant/.lock

# ==============================================================================
# IDE & OS Artifacts
# ==============================================================================
.vscode/
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ==============================================================================
# Logs & Temp
# ==============================================================================
*.log
*.tmp
*.bak

# ==============================================================================
# Documentation files (kept locally, not committed)
# ==============================================================================
*.docx
*.doc
